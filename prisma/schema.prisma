generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// LOCATIONS — MAGNOLIA (MG) and ORIZONT (O)
// ============================================================
model Location {
  id        String   @id @default(cuid())
  code      String   @unique  // "MG", "O"
  name      String   @unique  // "MAGNOLIA", "ORIZONT"
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyIncomes     DailyIncome[]
  incomingInvoices IncomingInvoice[]
  outgoingInvoices OutgoingInvoice[]
  receipts         Receipt[]
  employees        Employee[]
  monthlyPnl       MonthlyPnL[]
  monthlyCashFlow  MonthlyCashFlow[]
  monthlyCogs      MonthlyCOGS[]
}

// ============================================================
// INPUT: INCOME SHEET — Daily sales per location
// One row per day per location
// ============================================================
model DailyIncome {
  id              String   @id @default(cuid())
  locationId      String
  date            DateTime
  dayOfWeek       String?           // "L", "Ma", "Mi", "J", "V", "S", "D"
  month           Int               // 1-12
  week            Int?              // Week number within month
  year            Int

  // Sales totals
  totalSales      Float    @default(0)  // MAGNOLIA / ORIZONT column (with TVA)
  tva             Float    @default(0)  // TVA
  salesExVat      Float    @default(0)  // FARA TVA
  receiptCount    Int      @default(0)  // Nr. bonuri
  avgReceipt      Float    @default(0)  // Cec mediu

  // Department breakdown
  barSales        Float    @default(0)  // BAR
  barProductCount Int      @default(0)  // Nr Produse BAR
  kitchenSales    Float    @default(0)  // BUCATARIE
  kitchenProductCount Int  @default(0)  // Nr Produse BUCATARIE

  // Payment methods
  cashAmount      Float    @default(0)  // CASH
  cardAmount      Float    @default(0)  // CARD
  transferAmount  Float    @default(0)  // VIRAMENT
  accountAmount   Float    @default(0)  // CONT
  deliveryAmount  Float    @default(0)  // LIVRATOR

  // Tips
  tipsFiscal      Float    @default(0)  // TIPS FISCAL
  tipsTotal       Float    @default(0)  // TIPS

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, date])
  @@index([year, month])
  @@index([date])
}

// ============================================================
// INPUT: RECEIPTS — Individual transactions (bonuri / incasari)
// ============================================================
model Receipt {
  id              String   @id @default(cuid())
  locationId      String
  date            DateTime
  type            String   @default("SALE")        // SALE, REFUND, EXPENSE
  description     String?
  category        String?                           // BAR, BUCATARIE, DIVERSE
  amount          Float    @default(0)
  paymentMethod   String   @default("CASH")        // CASH, CARD, TRANSFER
  receiptNumber   String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([date])
  @@index([type])
  @@index([paymentMethod])
}

// ============================================================
// INPUT: INTRARE FACTURI — Incoming invoices from suppliers
// ============================================================
model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique  // Denumire Firma
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices IncomingInvoice[]
}

model IncomingInvoice {
  id              String    @id @default(cuid())
  locationId      String                          // Locatie: MAGNOLIA / ORIZONT
  year            Int                             // An
  month           String                          // Luna: IANUARIE, FEBRUARIE, etc.
  plCategory      String                          // CATEGORIE P&L: COGS, COSTFIX, OPEX, TAXE
  category        String                          // Categorie: BAR, BUCATARIE, CHIRII, UTILITATI
  subcategory     String?                         // Subcategorie: MATERIE PRIMA, MARFA, etc.
  invoiceNumber   String                          // NR Factura
  supplierId      String                          // FK to Supplier
  issueDate       String?                         // Data Emitere (string — some bad formats)
  issueDateParsed DateTime?                       // Parsed date when possible
  dueDate         DateTime?                       // Scadenta
  itemDescription String?                         // Descriere articol (from Excel)
  qty             Float     @default(0)           // Cantitate
  unitPrice       Float     @default(0)           // Pret unitar
  amountExVat     Float     @default(0)           // Suma fara TVA
  vatAmount       Float     @default(0)           // Val TVA
  totalAmount     Float     @default(0)           // Suma de plata
  status          String    @default("UNPAID")    // PAID, UNPAID, PARTIAL
  paidAmount      Float     @default(0)           // Achitati
  paymentYear     Int?                            // An Plata
  paymentMonth    String?                         // Luna Plata
  paymentDay      Int?                            // Data (day of month)
  remainingAmount Float     @default(0)           // De plata
  notes           String?                         // Obs

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([year, month])
  @@index([plCategory])
  @@index([category])
  @@index([supplierId])
  @@index([locationId])
}

// ============================================================
// INPUT: IESIRE FACTURI — Outgoing invoices to customers
// ============================================================
model Customer {
  id        String   @id @default(cuid())
  name      String   @unique  // Denumire Firma
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices OutgoingInvoice[]
}

model OutgoingInvoice {
  id              String    @id @default(cuid())
  locationId      String?
  year            Int                             // An
  month           String                          // Luna
  invoiceNumber   String                          // NR Factura
  customerId      String                          // FK to Customer
  issueDate       DateTime?                       // Data Emitere
  dueDate         DateTime?                       // Scadenta
  amountExVat     Float     @default(0)           // Suma fara TVA
  totalAmount     Float     @default(0)           // Suma de plata
  paidAmount      Float     @default(0)           // ACHITAT
  paymentYear     Int?                            // An Plata
  paymentMonth    String?                         // Luna Plata
  paymentDay      Int?                            // ZI
  unpaidAmount    Float     @default(0)           // NEACHITAT
  status          String    @default("UNPAID")    // PAID, UNPAID, PARTIAL
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])

  @@index([year, month])
  @@index([customerId])
}

// ============================================================
// DASHBOARD: MONTHLY P&L — Per location, per month
// Mirrors MG P&L 2026 / O P&L 2026 sheets
// ============================================================
model MonthlyPnL {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int    // 1-12

  // A. INCOME
  totalIncome       Float @default(0)
  workingDays       Int   @default(0)
  receiptCount      Int   @default(0)
  unitSales         Float @default(0)
  avgReceipt        Float @default(0)
  avgDailySales     Float @default(0)
  barSales          Float @default(0)
  barProductCount   Int   @default(0)
  kitchenSales      Float @default(0)
  kitchenProductCount Int @default(0)
  deliverySales     Float @default(0)
  invoicedSales     Float @default(0)

  // B. COGS
  totalCogs         Float @default(0)
  cogsPercent       Float @default(0)
  costGoods         Float @default(0)
  costRawMaterials  Float @default(0)
  costTransport     Float @default(0)
  costPackaging     Float @default(0)
  costDeliveryComm  Float @default(0)
  costLosses        Float @default(0)
  costProtocol      Float @default(0)

  // C. PEOPLE
  totalPeople       Float @default(0)
  peoplePercent     Float @default(0)
  netFront          Float @default(0)
  collaborators     Float @default(0)
  salaryTaxes       Float @default(0)
  mealTickets       Float @default(0)
  salaryDiff        Float @default(0)
  freshService      Float @default(0)
  bonuses           Float @default(0)
  uniforms          Float @default(0)
  training          Float @default(0)
  recruitment       Float @default(0)
  medicalWork       Float @default(0)
  ssm               Float @default(0)
  hygieneCourses    Float @default(0)

  // D. OPEX
  totalOpex         Float @default(0)
  opexPercent       Float @default(0)
  licenses          Float @default(0)
  consulting        Float @default(0)
  accounting        Float @default(0)
  authorizations    Float @default(0)
  marketing         Float @default(0)
  diverseOpex       Float @default(0)
  objectInventory   Float @default(0)

  // E. FIXED COSTS
  totalFixedCosts   Float @default(0)
  fixedCostsPercent Float @default(0)
  rent              Float @default(0)
  utilities         Float @default(0)
  bankFees          Float @default(0)
  otherFixed        Float @default(0)

  // F. TAXES
  totalTaxes        Float @default(0)
  incomeTax         Float @default(0)
  vatPayable        Float @default(0)
  otherTaxes        Float @default(0)

  // G. FINANCING
  totalFinancing    Float @default(0)
  immInvest         Float @default(0)

  // CALCULATED
  grossProfit       Float @default(0)
  operatingProfit   Float @default(0)
  netProfit         Float @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// DASHBOARD: MONTHLY CASH FLOW — Per location, per month
// Mirrors MG Cash Flow 26 / O Cash Flow 26 sheets
// ============================================================
model MonthlyCashFlow {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int

  // INFLOWS
  openingBalance    Float @default(0)
  totalCollections  Float @default(0)
  locationSales     Float @default(0)
  invoiceCollections Float @default(0)
  deliveryIncome    Float @default(0)
  tipsMagnolia      Float @default(0)
  tipsOrizont       Float @default(0)
  cashInflow        Float @default(0)
  cardInflow        Float @default(0)
  transferInflow    Float @default(0)
  otherIncome       Float @default(0)
  totalInflows      Float @default(0)

  // OUTFLOWS — COGS
  cogsCash          Float @default(0)
  cogsBar           Float @default(0)
  cogsKitchen       Float @default(0)
  cogsConsumables   Float @default(0)
  cogsTransport     Float @default(0)
  cogsDeliveryComm  Float @default(0)

  // OUTFLOWS — OPEX
  opexTotal         Float @default(0)
  peopleCash        Float @default(0)
  licensesCash      Float @default(0)
  servicesCash      Float @default(0)
  authorizationsCash Float @default(0)
  diverseCash       Float @default(0)
  marketingCash     Float @default(0)
  investmentsCash   Float @default(0)

  // OUTFLOWS — FIXED COSTS
  fixedCostsCash    Float @default(0)
  rentCash          Float @default(0)
  utilitiesCash     Float @default(0)
  bankFeesCash      Float @default(0)

  // OUTFLOWS — TAXES
  taxesCash         Float @default(0)
  incomeTaxCash     Float @default(0)
  vatCash           Float @default(0)
  otherTaxesCash    Float @default(0)

  // OTHER
  dividends         Float @default(0)
  capitalInput      Float @default(0)
  totalOutflows     Float @default(0)
  closingBalance    Float @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// DASHBOARD: MONTHLY COGS — Per location, per month
// Mirrors MG COGS 2026 / O COGS 2026 sheets
// ============================================================
model MonthlyCOGS {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int

  // Materie Prima
  rawMaterialOpenStock  Float @default(0)
  rawMaterialPurchases  Float @default(0)
  rawMaterialOutgoing   Float @default(0)
  rawMaterialCloseStock Float @default(0)
  rawMaterialCost       Float @default(0)

  // Marfa
  goodsOpenStock        Float @default(0)
  goodsPurchases        Float @default(0)
  goodsOutgoing         Float @default(0)
  goodsCloseStock       Float @default(0)
  goodsCost             Float @default(0)

  // Ambalaje
  packagingOpenStock    Float @default(0)
  packagingPurchases    Float @default(0)
  packagingOutgoing     Float @default(0)
  packagingCloseStock   Float @default(0)
  packagingCost         Float @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// REFERENCE: EMPLOYEES — SALARIATI sheet
// ============================================================
model Employee {
  id              String  @id @default(cuid())
  locationId      String
  department      String              // BUCATARIE, BAR, ADMINISTRATIV
  position        String              // RESPONSABIL BUCATARIE, BARISTA 1, etc.
  grossSalary     Float   @default(0)
  netSalary       Float   @default(0)
  salaryTaxes     Float   @default(0)
  mealTickets     Float   @default(0)
  monthsWorked    Int     @default(11)
  monthsPaid      Int     @default(12)
  annualCost      Float   @default(0)
  isActive        Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([department])
}

// ============================================================
// REFERENCE: P&L CATEGORY TAXONOMY — Nomenclator
// ============================================================
model PlCategory {
  id            String @id @default(cuid())
  code          String @unique  // COGS, OPEX, COSTFIX, TAXE, PEOPLE
  name          String
  sortOrder     Int    @default(0)

  subcategories PlSubcategory[]
}

model PlSubcategory {
  id         String @id @default(cuid())
  categoryId String
  code       String
  name       String
  sortOrder  Int    @default(0)

  category PlCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, code])
}

// ============================================================
// REFERENCE: DIVIDENDS
// ============================================================
model Dividend {
  id               String    @id @default(cuid())
  paymentDate      DateTime?
  raiffeisenAmount Float     @default(0)
  garantiAmount    Float     @default(0)
  totalWithTaxes   Float     @default(0)
  dividendAmount   Float     @default(0)
  balance          Float     @default(0)
  notes            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ============================================================
// REFERENCE: FORECAST
// ============================================================
model MonthlyForecast {
  id             String @id @default(cuid())
  year           Int
  month          Int
  indicator      String
  magnoliaValue  Float  @default(0)
  orizontValue   Float  @default(0)
  totalValue     Float  @default(0)

  @@unique([year, month, indicator])
  @@index([year, month])
}

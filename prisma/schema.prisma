generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// LOCATIONS — MAGNOLIA (MG) and ORIZONT (O)
// ============================================================
model Location {
  id        String   @id @default(cuid())
  code      String   @unique  // "MG", "O"
  name      String   @unique  // "MAGNOLIA", "ORIZONT"
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyIncomes     DailyIncome[]
  incomingInvoices IncomingInvoice[]
  outgoingInvoices OutgoingInvoice[]
  receipts         Receipt[]
  employees        Employee[]
  monthlyPnl       MonthlyPnL[]
  monthlyCashFlow  MonthlyCashFlow[]
  monthlyCogs      MonthlyCOGS[]
}

// ============================================================
// INPUT: INCOME SHEET — Daily sales per location
// One row per day per location
// ============================================================
model DailyIncome {
  id              String   @id @default(cuid())
  locationId      String
  date            DateTime
  dayOfWeek       String?           // "L", "Ma", "Mi", "J", "V", "S", "D"
  month           Int               // 1-12
  week            Int?              // Week number within month
  year            Int

  // Sales totals
  totalSales      Decimal    @default(0)  // MAGNOLIA / ORIZONT column (with TVA)
  tva             Decimal    @default(0)  // TVA
  salesExVat      Decimal    @default(0)  // FARA TVA
  receiptCount    Int      @default(0)  // Nr. bonuri
  avgReceipt      Decimal    @default(0)  // Cec mediu

  // Department breakdown
  barSales        Decimal    @default(0)  // BAR
  barProductCount Int      @default(0)  // Nr Produse BAR
  kitchenSales    Decimal    @default(0)  // BUCATARIE
  kitchenProductCount Int  @default(0)  // Nr Produse BUCATARIE

  // Payment methods
  cashAmount      Decimal    @default(0)  // CASH
  cardAmount      Decimal    @default(0)  // CARD
  transferAmount  Decimal    @default(0)  // VIRAMENT
  accountAmount   Decimal    @default(0)  // CONT
  deliveryAmount  Decimal    @default(0)  // LIVRATOR

  // Tips
  tipsFiscal      Decimal    @default(0)  // TIPS FISCAL
  tipsTotal       Decimal    @default(0)  // TIPS

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, date])
  @@index([year, month])
  @@index([date])
}

// ============================================================
// INPUT: RECEIPTS — Individual transactions (bonuri / incasari)
// ============================================================
model Receipt {
  id              String   @id @default(cuid())
  locationId      String
  date            DateTime
  type            String   @default("SALE")        // SALE, REFUND, EXPENSE
  description     String?
  category        String?                           // BAR, BUCATARIE, DIVERSE
  amount          Decimal    @default(0)
  paymentMethod   String   @default("CASH")        // CASH, CARD, TRANSFER
  receiptNumber   String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([date])
  @@index([type])
  @@index([paymentMethod])
}

// ============================================================
// INPUT: INTRARE FACTURI — Incoming invoices from suppliers
// ============================================================
model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique  // Denumire Firma
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices IncomingInvoice[]
}

model IncomingInvoice {
  id              String    @id @default(cuid())
  locationId      String                          // Locatie: MAGNOLIA / ORIZONT
  year            Int                             // An
  month           String                          // Luna: IANUARIE, FEBRUARIE, etc.
  plCategory      String                          // CATEGORIE P&L: COGS, COSTFIX, OPEX, TAXE
  category        String                          // Categorie: BAR, BUCATARIE, CHIRII, UTILITATI
  subcategory     String?                         // Subcategorie: MATERIE PRIMA, MARFA, etc.
  invoiceNumber   String                          // NR Factura
  supplierId      String                          // FK to Supplier
  issueDate       String?                         // Data Emitere (string — some bad formats)
  issueDateParsed DateTime?                       // Parsed date when possible
  dueDate         DateTime?                       // Scadenta
  itemDescription String?                         // Descriere articol (from Excel)
  qty             Decimal     @default(0)           // Cantitate
  unitPrice       Decimal     @default(0)           // Pret unitar
  amountExVat     Decimal     @default(0)           // Suma fara TVA
  vatAmount       Decimal     @default(0)           // Val TVA
  totalAmount     Decimal     @default(0)           // Suma de plata
  status          String    @default("UNPAID")    // PAID, UNPAID, PARTIAL
  paidAmount      Decimal     @default(0)           // Achitati
  paymentYear     Int?                            // An Plata
  paymentMonth    String?                         // Luna Plata
  paymentDay      Int?                            // Data (day of month)
  remainingAmount Decimal     @default(0)           // De plata
  notes           String?                         // Obs

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([year, month])
  @@index([plCategory])
  @@index([category])
  @@index([supplierId])
  @@index([locationId])
}

// ============================================================
// INPUT: IESIRE FACTURI — Outgoing invoices to customers
// ============================================================
model Customer {
  id        String   @id @default(cuid())
  name      String   @unique  // Denumire Firma
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices OutgoingInvoice[]
}

model OutgoingInvoice {
  id              String    @id @default(cuid())
  locationId      String?
  year            Int                             // An
  month           String                          // Luna
  invoiceNumber   String                          // NR Factura
  customerId      String                          // FK to Customer
  issueDate       DateTime?                       // Data Emitere
  dueDate         DateTime?                       // Scadenta
  amountExVat     Decimal     @default(0)           // Suma fara TVA
  totalAmount     Decimal     @default(0)           // Suma de plata
  paidAmount      Decimal     @default(0)           // ACHITAT
  paymentYear     Int?                            // An Plata
  paymentMonth    String?                         // Luna Plata
  paymentDay      Int?                            // ZI
  unpaidAmount    Decimal     @default(0)           // NEACHITAT
  status          String    @default("UNPAID")    // PAID, UNPAID, PARTIAL
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])

  @@index([year, month])
  @@index([customerId])
}

// ============================================================
// DASHBOARD: MONTHLY P&L — Per location, per month
// Mirrors MG P&L 2026 / O P&L 2026 sheets
// ============================================================
model MonthlyPnL {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int    // 1-12

  // A. INCOME
  totalIncome       Decimal @default(0)
  workingDays       Int   @default(0)
  receiptCount      Int   @default(0)
  unitSales         Decimal @default(0)
  avgReceipt        Decimal @default(0)
  avgDailySales     Decimal @default(0)
  barSales          Decimal @default(0)
  barProductCount   Int   @default(0)
  kitchenSales      Decimal @default(0)
  kitchenProductCount Int @default(0)
  deliverySales     Decimal @default(0)
  invoicedSales     Decimal @default(0)

  // B. COGS
  totalCogs         Decimal @default(0)
  cogsPercent       Decimal @default(0)
  costGoods         Decimal @default(0)
  costRawMaterials  Decimal @default(0)
  costTransport     Decimal @default(0)
  costPackaging     Decimal @default(0)
  costDeliveryComm  Decimal @default(0)
  costLosses        Decimal @default(0)
  costProtocol      Decimal @default(0)

  // C. PEOPLE
  totalPeople       Decimal @default(0)
  peoplePercent     Decimal @default(0)
  netFront          Decimal @default(0)
  collaborators     Decimal @default(0)
  salaryTaxes       Decimal @default(0)
  mealTickets       Decimal @default(0)
  salaryDiff        Decimal @default(0)
  freshService      Decimal @default(0)
  bonuses           Decimal @default(0)
  uniforms          Decimal @default(0)
  training          Decimal @default(0)
  recruitment       Decimal @default(0)
  medicalWork       Decimal @default(0)
  ssm               Decimal @default(0)
  hygieneCourses    Decimal @default(0)

  // D. OPEX
  totalOpex         Decimal @default(0)
  opexPercent       Decimal @default(0)
  licenses          Decimal @default(0)
  consulting        Decimal @default(0)
  accounting        Decimal @default(0)
  authorizations    Decimal @default(0)
  marketing         Decimal @default(0)
  diverseOpex       Decimal @default(0)
  objectInventory   Decimal @default(0)

  // E. FIXED COSTS
  totalFixedCosts   Decimal @default(0)
  fixedCostsPercent Decimal @default(0)
  rent              Decimal @default(0)
  utilities         Decimal @default(0)
  bankFees          Decimal @default(0)
  otherFixed        Decimal @default(0)

  // F. TAXES
  totalTaxes        Decimal @default(0)
  incomeTax         Decimal @default(0)
  vatPayable        Decimal @default(0)
  otherTaxes        Decimal @default(0)

  // G. FINANCING
  totalFinancing    Decimal @default(0)
  immInvest         Decimal @default(0)

  // CALCULATED
  grossProfit       Decimal @default(0)
  operatingProfit   Decimal @default(0)
  netProfit         Decimal @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// DASHBOARD: MONTHLY CASH FLOW — Per location, per month
// Mirrors MG Cash Flow 26 / O Cash Flow 26 sheets
// ============================================================
model MonthlyCashFlow {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int

  // INFLOWS
  openingBalance    Decimal @default(0)
  totalCollections  Decimal @default(0)
  locationSales     Decimal @default(0)
  invoiceCollections Decimal @default(0)
  deliveryIncome    Decimal @default(0)
  tipsMagnolia      Decimal @default(0)
  tipsOrizont       Decimal @default(0)
  cashInflow        Decimal @default(0)
  cardInflow        Decimal @default(0)
  transferInflow    Decimal @default(0)
  otherIncome       Decimal @default(0)
  totalInflows      Decimal @default(0)

  // OUTFLOWS — COGS
  cogsCash          Decimal @default(0)
  cogsBar           Decimal @default(0)
  cogsKitchen       Decimal @default(0)
  cogsConsumables   Decimal @default(0)
  cogsTransport     Decimal @default(0)
  cogsDeliveryComm  Decimal @default(0)

  // OUTFLOWS — OPEX
  opexTotal         Decimal @default(0)
  peopleCash        Decimal @default(0)
  licensesCash      Decimal @default(0)
  servicesCash      Decimal @default(0)
  authorizationsCash Decimal @default(0)
  diverseCash       Decimal @default(0)
  marketingCash     Decimal @default(0)
  investmentsCash   Decimal @default(0)

  // OUTFLOWS — FIXED COSTS
  fixedCostsCash    Decimal @default(0)
  rentCash          Decimal @default(0)
  utilitiesCash     Decimal @default(0)
  bankFeesCash      Decimal @default(0)

  // OUTFLOWS — TAXES
  taxesCash         Decimal @default(0)
  incomeTaxCash     Decimal @default(0)
  vatCash           Decimal @default(0)
  otherTaxesCash    Decimal @default(0)

  // OTHER
  dividends         Decimal @default(0)
  capitalInput      Decimal @default(0)
  totalOutflows     Decimal @default(0)
  closingBalance    Decimal @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// DASHBOARD: MONTHLY COGS — Per location, per month
// Mirrors MG COGS 2026 / O COGS 2026 sheets
// ============================================================
model MonthlyCOGS {
  id              String @id @default(cuid())
  locationId      String
  year            Int
  month           Int

  // Materie Prima
  rawMaterialOpenStock  Decimal @default(0)
  rawMaterialPurchases  Decimal @default(0)
  rawMaterialOutgoing   Decimal @default(0)
  rawMaterialCloseStock Decimal @default(0)
  rawMaterialCost       Decimal @default(0)

  // Marfa
  goodsOpenStock        Decimal @default(0)
  goodsPurchases        Decimal @default(0)
  goodsOutgoing         Decimal @default(0)
  goodsCloseStock       Decimal @default(0)
  goodsCost             Decimal @default(0)

  // Ambalaje
  packagingOpenStock    Decimal @default(0)
  packagingPurchases    Decimal @default(0)
  packagingOutgoing     Decimal @default(0)
  packagingCloseStock   Decimal @default(0)
  packagingCost         Decimal @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, year, month])
  @@index([year, month])
}

// ============================================================
// REFERENCE: EMPLOYEES — SALARIATI sheet
// ============================================================
model Employee {
  id              String  @id @default(cuid())
  locationId      String
  department      String              // BUCATARIE, BAR, ADMINISTRATIV
  position        String              // RESPONSABIL BUCATARIE, BARISTA 1, etc.
  grossSalary     Decimal   @default(0)
  netSalary       Decimal   @default(0)
  salaryTaxes     Decimal   @default(0)
  mealTickets     Decimal   @default(0)
  monthsWorked    Int     @default(11)
  monthsPaid      Int     @default(12)
  annualCost      Decimal   @default(0)
  isActive        Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId])
  @@index([department])
}

// ============================================================
// REFERENCE: P&L CATEGORY TAXONOMY — Nomenclator
// ============================================================
model PlCategory {
  id            String @id @default(cuid())
  code          String @unique  // COGS, OPEX, COSTFIX, TAXE, PEOPLE
  name          String
  sortOrder     Int    @default(0)

  subcategories PlSubcategory[]
}

model PlSubcategory {
  id         String @id @default(cuid())
  categoryId String
  code       String
  name       String
  sortOrder  Int    @default(0)

  category PlCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, code])
}

// ============================================================
// REFERENCE: DIVIDENDS
// ============================================================
model Dividend {
  id               String    @id @default(cuid())
  paymentDate      DateTime?
  raiffeisenAmount Decimal     @default(0)
  garantiAmount    Decimal     @default(0)
  totalWithTaxes   Decimal     @default(0)
  dividendAmount   Decimal     @default(0)
  balance          Decimal     @default(0)
  notes            String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ============================================================
// AUTH: ALLOWED EMAILS — Whitelist for login
// ============================================================
model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String?
  createdAt DateTime @default(now())
}

// ============================================================
// REFERENCE: FORECAST
// ============================================================
model MonthlyForecast {
  id             String @id @default(cuid())
  year           Int
  month          Int
  indicator      String
  magnoliaValue  Decimal  @default(0)
  orizontValue   Decimal  @default(0)
  totalValue     Decimal  @default(0)

  @@unique([year, month, indicator])
  @@index([year, month])
}
